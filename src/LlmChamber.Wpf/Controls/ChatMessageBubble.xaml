<UserControl x:Class="LlmChamber.Wpf.Controls.ChatMessageBubble"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:LlmChamber.Wpf.Controls"
             x:Name="Root">
    <UserControl.Resources>
        <local:ChatRoleToBackgroundConverter x:Key="RoleToBackground" />
        <local:ChatRoleToAlignmentConverter x:Key="RoleToAlignment" />
        <local:ChatRoleToFontStyleConverter x:Key="RoleToFontStyle" />
        <local:ChatRoleToLabelConverter x:Key="RoleToLabel" />
    </UserControl.Resources>

    <Border Margin="4,4,4,4"
            Padding="12,8,12,8"
            CornerRadius="8"
            MaxWidth="600"
            HorizontalAlignment="{Binding Message.Role, ElementName=Root, Converter={StaticResource RoleToAlignment}}"
            Background="{Binding Message.Role, ElementName=Root, Converter={StaticResource RoleToBackground}}">
        <StackPanel>
            <!-- ロールラベル -->
            <TextBlock Text="{Binding Message.Role, ElementName=Root, Converter={StaticResource RoleToLabel}}"
                       FontSize="11"
                       FontWeight="Bold"
                       Foreground="#666666"
                       Margin="0,0,0,4" />
            <!-- メッセージ本文 -->
            <TextBlock Text="{Binding Message.Content, ElementName=Root}"
                       TextWrapping="Wrap"
                       FontSize="14"
                       FontStyle="{Binding Message.Role, ElementName=Root, Converter={StaticResource RoleToFontStyle}}"
                       Foreground="#1A1A1A" />
        </StackPanel>
    </Border>
</UserControl>
