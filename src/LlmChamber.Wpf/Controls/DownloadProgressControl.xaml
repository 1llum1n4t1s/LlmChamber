<UserControl x:Class="LlmChamber.Wpf.Controls.DownloadProgressControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Padding="12">
    <StackPanel>
        <!-- GPU情報 -->
        <TextBlock x:Name="GpuInfoText"
                   FontSize="12"
                   Foreground="#616161"
                   Margin="0,0,0,12">
            <Run Text="検出GPU: " />
            <Run x:Name="GpuInfoRun" Text="-" />
        </TextBlock>

        <!-- ランタイムダウンロード -->
        <StackPanel x:Name="RuntimeSection" Margin="0,0,0,12">
            <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,4">
                <Run Text="ランタイム" />
            </TextBlock>
            <ProgressBar x:Name="RuntimeProgressBar"
                         Height="20"
                         Minimum="0" Maximum="100" Value="0"
                         Foreground="#43A047" />
            <TextBlock x:Name="RuntimeStatusText"
                       FontSize="11"
                       Foreground="#757575"
                       Margin="0,4,0,0"
                       Text="待機中..." />
        </StackPanel>

        <!-- モデルダウンロード -->
        <StackPanel x:Name="ModelSection">
            <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,4">
                <Run Text="モデル" />
            </TextBlock>
            <ProgressBar x:Name="ModelProgressBar"
                         Height="20"
                         Minimum="0" Maximum="100" Value="0"
                         Foreground="#1976D2" />
            <TextBlock x:Name="ModelStatusText"
                       FontSize="11"
                       Foreground="#757575"
                       Margin="0,4,0,0"
                       Text="待機中..." />
        </StackPanel>
    </StackPanel>
</UserControl>
