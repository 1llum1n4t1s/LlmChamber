<Window x:Class="Sample.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:LlmChamber.Wpf.Controls;assembly=LlmChamber.Wpf"
        Title="LlmChamber - WPF Sample" Height="700" Width="900"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- メニューバー -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar Band="0" BandIndex="0">
                <TextBlock Text="モデル:" VerticalAlignment="Center" Margin="4,0"/>
                <ComboBox x:Name="ModelComboBox" Width="160" SelectedIndex="0" Margin="4,0">
                    <ComboBoxItem Content="gemma4-e2b"/>
                    <ComboBoxItem Content="gemma4-e4b"/>
                    <ComboBoxItem Content="qwen3.5-2b"/>
                    <ComboBoxItem Content="phi4-mini"/>
                </ComboBox>
                <Separator/>
                <TextBlock Text="バリアント:" VerticalAlignment="Center" Margin="4,0"/>
                <ComboBox x:Name="VariantComboBox" Width="120" SelectedIndex="0" Margin="4,0">
                    <ComboBoxItem Content="Auto"/>
                    <ComboBoxItem Content="Full"/>
                    <ComboBoxItem Content="Rocm"/>
                    <ComboBoxItem Content="CpuOnly"/>
                </ComboBox>
                <Separator/>
                <Button x:Name="ConnectButton" Content="接続" Click="ConnectButton_Click" Padding="12,4" Margin="4,0"/>
            </ToolBar>
        </ToolBarTray>

        <!-- ステータスバー -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusBarText" Text="未接続"/>
            </StatusBarItem>
        </StatusBar>

        <!-- メインコンテンツ -->
        <Grid>
            <!-- ダウンロード進捗（初期化中に表示） -->
            <controls:DownloadProgressControl x:Name="DownloadProgress"
                                              Visibility="Collapsed"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              Margin="40"/>

            <!-- チャットコントロール -->
            <controls:ChatControl x:Name="ChatControl"
                                  Visibility="Collapsed"/>
        </Grid>
    </DockPanel>
</Window>
